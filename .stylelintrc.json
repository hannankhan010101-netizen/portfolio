{
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "theme",
          "tailwind",
          "layer",
          "apply",
          "variants",
          "responsive",
          "screen",
          "import"
        ]
      }
    ],
    "no-empty-source": null
  }
}
