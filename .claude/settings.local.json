{
  "permissions": {
    "allow": [
      "Bash(npx tsc *)",
      "Bash(pnpm add *)",
      "Bash(pnpm build *)",
      "Bash(pnpm install *)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(pnpm dev *)",
      "Bash(pnpm dev:3000)",
      "Bash(netstat -ano)",
      "Bash(findstr \":4000 \\\\|:3000 \")",
      "Bash(tasklist *)",
      "PowerShell(Get-Process *)",
      "Bash(curl *)",
      "PowerShell(try { $r = Invoke-WebRequest -Uri \"http://localhost:4000\" -TimeoutSec 5 -UseBasicParsing; \"Status: $\\($r.StatusCode\\)\" } catch { \"Error: $_\" })",
      "Bash(pnpm next *)",
      "PowerShell(try { $r = Invoke-WebRequest -Uri \"http://localhost:4000\" -TimeoutSec 10 -UseBasicParsing; \"HTTP $\\($r.StatusCode\\) — $\\($r.Content.Length\\) bytes\" } catch { \"Error: $_\" })",
      "PowerShell($conn = New-Object System.Net.Sockets.TcpClient; try { $conn.Connect\\(\"127.0.0.1\", 4000\\); \"TCP connected to port 4000 — server is up\" } catch { \"TCP failed: $_\" } finally { $conn.Close\\(\\) })",
      "PowerShell(Stop-Process *)",
      "PowerShell(Get-NetTCPConnection *)",
      "PowerShell($p = Get-Process -Id 17604 -ErrorAction SilentlyContinue; if \\($p\\) { $p.MainModule.FileName + \" | \" + \\($p | Select-Object -ExpandProperty CommandLine -ErrorAction SilentlyContinue\\) })",
      "Bash(npm run *)"
    ]
  }
}
